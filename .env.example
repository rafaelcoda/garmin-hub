# ─── Garmin OAuth 1.0a ───────────────────────────────────────────────────────
GARMIN_CONSUMER_KEY=sua_consumer_key
GARMIN_CONSUMER_SECRET=seu_consumer_secret

# Preenchido automaticamente após autenticação via /api/auth/callback
GARMIN_ACCESS_TOKEN=
GARMIN_ACCESS_TOKEN_SECRET=

# ─── Anthropic (análises com IA) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sua_chave_anthropic

# ─── App ──────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=gere_com_openssl_rand_base64_32

# ─── URLs Garmin ──────────────────────────────────────────────────────────────
GARMIN_OAUTH_BASE=https://connectapi.garmin.com
GARMIN_HEALTH_API_BASE=https://healthapi.garmin.com/wellness-api/rest
